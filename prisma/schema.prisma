// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  firstName String
  lastName  String?
  files     File[]   @relation("UploadedFile")
  folders   Folder[] @relation("CreatedFolder")
}

model File {
  id         Int      @id @default(autoincrement())
  name       String
  size       String
  uploadTime DateTime
  path       String
  author     User     @relation("UploadedFile", fields: [authorId], references: [id])
  authorId   Int
  folder     Folder?  @relation("DestFolder", fields: [folderId], references: [id])
  folderId   Int?
}

model Folder {
  id       Int    @id @default(autoincrement())
  name     String
  author   User   @relation("CreatedFolder", fields: [authorId], references: [id])
  authorId Int
  files    File[] @relation("DestFolder")
}
